---
import type { HTMLAttributes } from "astro/types";
import { SOCIALS } from "@/constants";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="flex flex-col gap-3 border-t border-border py-10 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between"
  >
    <span>&copy; {currentYear} Umar Bin Moiz</span>
    {
      SOCIALS.length > 0 && (
        <ul class="flex gap-5">
          {SOCIALS.map(social => (
            <li>
              <a
                href={social.href}
                title={social.linkTitle}
                target={social.href.startsWith("mailto:") ? undefined : "_blank"}
                rel="noopener noreferrer"
                class="transition-colors hover:text-foreground"
              >
                {social.name}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</footer>
